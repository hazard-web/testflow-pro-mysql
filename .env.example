# ──────────────────────────────────────────
# TestFlow Pro — Environment Variables Example
# ──────────────────────────────────────────
# Copy this file to .env and update with your actual values
# NEVER commit the .env file to git

# ── Application ──
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# ── Database (MySQL) ──
DB_HOST=mysql
DB_PORT=3306
DB_NAME=testflow_dev
DB_USER=testflow_user
DB_PASSWORD=testflow_pass
DB_ROOT_PASSWORD=rootpassword
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=10

# ── Redis (sessions / cache) ──
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT Authentication ──
JWT_SECRET=dev_jwt_secret_change_in_prod_min32chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=dev_refresh_secret_change_in_prod_min32chars
JWT_REFRESH_EXPIRES_IN=30d

# ── Email (nodemailer / Mailtrap for dev) ──
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USER=your_mailtrap_user
MAIL_PASS=your_mailtrap_pass
MAIL_FROM=noreply@testflow.dev

# ── File Uploads ──
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# ── Rate Limiting ──
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1000

# ── Logging ──
LOG_LEVEL=debug

# ── Frontend (Vite) ──
VITE_API_URL=http://localhost:5000/api
VITE_BACKEND_URL=http://backend:5000
VITE_APP_NAME=TestFlow Pro
VITE_ENV=development

# ── Security ──
TRUST_PROXY=1

# ── IMPORTANT PRODUCTION NOTES ──
# 1. Change JWT_SECRET to a strong random 32+ character string
# 2. Change JWT_REFRESH_SECRET to a different strong random string
# 3. Use strong database passwords
# 4. Update MAIL_* settings with real email service credentials
# 5. Set NODE_ENV=production for production deployments
# 6. Use HTTPS in production (CLIENT_URL should be https://)
# 7. Store all secrets securely (AWS Secrets Manager, HashiCorp Vault, etc)
