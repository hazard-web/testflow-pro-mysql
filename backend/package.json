{
  "name": "qa-assist-backend",
  "version": "1.0.0",
  "description": "QA Assist — Express API Server (MySQL)",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/config/migrate.js && node src/server.js",
    "migrate": "node src/config/migrate.js",
    "seed": "node src/config/seed.js",
    "db:reset": "node src/config/migrate.js --reset && node src/config/seed.js",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@sendgrid/mail": "^8.1.6",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.9.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.9.4",
    "nodemailer": "^8.0.3",
    "pdfkit": "^0.13.0",
    "qrcode": "^1.5.3",
    "redis": "^4.6.13",
    "speakeasy": "^2.0.0",
    "uuid": "^9.0.1",
    "winston": "^3.13.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.1",
    "supertest": "^7.0.0"
  }
}
