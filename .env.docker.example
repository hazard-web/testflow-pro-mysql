# Docker Environment Variables
# Copy to .env.docker and update with your values for production

# ─────────────────────────────
# Database (MySQL)
# ─────────────────────────────
DB_HOST=mysql
DB_PORT=3306
DB_NAME=testflow_dev
DB_USER=testflow_user
DB_PASSWORD=testflow_pass
DB_ROOT_PASSWORD=rootpassword
DB_SSL=false

# ─────────────────────────────
# Redis
# ─────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ─────────────────────────────
# Backend
# ─────────────────────────────
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# ─────────────────────────────
# JWT (CHANGE IN PRODUCTION!)
# ─────────────────────────────
JWT_SECRET=dev_jwt_secret_change_in_prod_min32chars
JWT_EXPIRES_IN=7d

# ─────────────────────────────
# API Settings
# ─────────────────────────────
RATE_LIMIT_MAX=200
LOG_LEVEL=debug

# ─────────────────────────────
# Frontend
# ─────────────────────────────
VITE_API_URL=http://localhost:5000/api
VITE_ENV=development
